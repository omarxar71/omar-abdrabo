{% comment %}
  Custom Banner Section - "The Gift Guide" style hero
  Built for Ecomexperts test - matches Figma banner frame
{% endcomment %}

<div class="gift-banner" style="background-color: {{ section.settings.background_color }};">

    {% comment %} Top thin bar with text + yellow button {% endcomment %}
    <div class="gift-banner__top-bar">
      <p class="gift-banner__top-text">{{ section.settings.top_bar_text }}</p>
  
      {% if section.settings.top_bar_button_text != blank %}
        <a href="{{ section.settings.top_bar_button_link }}" class="gift-banner__btn gift-banner__btn--yellow">
          {{ section.settings.top_bar_button_text }}
          <span class="gift-banner__arrow">→</span>
        </a>
      {% endif %}
    </div>
  
    {% comment %} Main hero content {% endcomment %}
    <div class="gift-banner__hero">
      <div class="gift-banner__content">
        <h1 class="gift-banner__heading">{{ section.settings.heading }}</h1>
  
        {% if section.settings.description != blank %}
          <div class="gift-banner__description">
            {{ section.settings.description }}
          </div>
        {% endif %}
  
        {% if section.settings.button_text != blank %}
          <a href="{{ section.settings.button_link }}" class="gift-banner__btn gift-banner__btn--dark">
            {{ section.settings.button_text }}
            <span class="gift-banner__arrow">→</span>
          </a>
        {% endif %}
      </div>
  
      {% comment %} Decorative background image (the line-art doodles) {% endcomment %}
      {% if section.settings.background_image %}
        <div class="gift-banner__image">
          <img
            src="{{ section.settings.background_image | image_url: width: 1500 }}"
            alt=""
            loading="lazy"
            width="{{ section.settings.background_image.width }}"
            height="{{ section.settings.background_image.height }}"
          >
        </div>
      {% endif %}
    </div>
  
    {% comment %} Bottom thin gray bar {% endcomment %}
    {% if section.settings.bottom_bar_text != blank %}
      <div class="gift-banner__bottom-bar">
        <p>{{ section.settings.bottom_bar_text }}</p>
      </div>
    {% endif %}
  
  </div>
  
  {% schema %}
  {
    "name": "Gift Banner",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "label": "Background color",
        "default": "#ffffff"
      },
      {
        "type": "text",
        "id": "top_bar_text",
        "label": "Top bar text",
        "default": "Find the ideal gift for your loved ones."
      },
      {
        "type": "text",
        "id": "top_bar_button_text",
        "label": "Top bar button text",
        "default": "Choose gift"
      },
      {
        "type": "url",
        "id": "top_bar_button_link",
        "label": "Top bar button link"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "The Gift Guide"
      },
      {
        "type": "richtext",
        "id": "description",
        "label": "Description",
        "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination.</p>"
      },
      {
        "type": "text",
        "id": "button_text",
        "label": "Button text",
        "default": "Shop now"
      },
      {
        "type": "url",
        "id": "button_link",
        "label": "Button link"
      },
      {
        "type": "image_picker",
        "id": "background_image",
        "label": "Decorative image"
      },
      {
        "type": "text",
        "id": "bottom_bar_text",
        "label": "Bottom bar text",
        "default": "Sustainable, ethically made clothes in sizes XXS to 6XL"
      }
    ],
    "presets": [
      {
        "name": "Gift Banner"
      }
    ]
  }
  {% endschema %}