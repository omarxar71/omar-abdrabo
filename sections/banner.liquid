{% comment %}
  Custom Banner Section - "The Gift Guide" style hero
  Built for Ecomexperts test - matches Figma banner frame
{% endcomment %}

<div
  class="gift-banner"
  style="--gift-banner-bg: {{ section.settings.background_color }};"
  id="GiftBanner-{{ section.id }}"
>
  <div class="gift-banner__hero{% if section.settings.background_image %} gift-banner__hero--has-image{% endif %}">
    {% if section.settings.background_image %}
      <div class="gift-banner__image gift-banner__image--bg">
        <img
          src="{{ section.settings.background_image | image_url: width: 1500 }}"
          alt=""
          loading="eager"
          width="{{ section.settings.background_image.width }}"
          height="{{ section.settings.background_image.height }}"
        >
      </div>
    {% endif %}

    <div class="gift-banner__content">
      <h1 class="gift-banner__heading">{{ section.settings.heading }}</h1>

      {% if section.settings.description != blank %}
        <div class="gift-banner__description">
          {{ section.settings.description }}
        </div>
      {% endif %}

      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_link }}" class="gift-banner__btn gift-banner__btn--dark">
          {{ section.settings.button_text | upcase }}
          <span class="gift-banner__arrow" aria-hidden="true">→</span>
        </a>
      {% endif %}
    </div>

    {% if section.settings.background_image %}
      <div class="gift-banner__image gift-banner__image--desktop">
        <img
          src="{{ section.settings.background_image | image_url: width: 1500 }}"
          alt=""
          loading="lazy"
          width="{{ section.settings.background_image.width }}"
          height="{{ section.settings.background_image.height }}"
        >
      </div>
    {% endif %}
  </div>

  {% if section.settings.bottom_bar_text != blank %}
    <div class="gift-banner__bottom-bar">
      <p>{{ section.settings.bottom_bar_text | upcase }}</p>
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .gift-banner {
    --gift-yellow: #fff251;
    --gift-gray: #f2f2f2;
    --gift-dark: #1a1a1a;
    background-color: var(--gift-banner-bg, #fff);
    color: var(--gift-dark);
    font-family: var(--font-body--family, system-ui, sans-serif);
  }

  .gift-banner__hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 32px 20px 40px;
    position: relative;
    overflow: hidden;
    min-height: 480px;
  }

  .gift-banner__hero--has-image {
    justify-content: center;
  }

  .gift-banner__content {
    position: relative;
    z-index: 2;
    max-width: 560px;
    width: 100%;
  }

  .gift-banner__heading {
    margin: 0 0 12px;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .gift-banner__description {
    margin-bottom: 24px;
    font-size: 0.875rem;
    line-height: 1.6;
    color: #333;
  }

  .gift-banner__description p {
    margin: 0;
  }

  .gift-banner__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s ease;
    white-space: nowrap;
  }

  .gift-banner__btn:hover {
    opacity: 0.85;
  }

  .gift-banner__btn--dark {
    background-color: var(--gift-dark);
    color: #fff;
  }

  .gift-banner__arrow {
    font-size: 1rem;
    line-height: 1;
  }

  .gift-banner__image {
    pointer-events: none;
  }

  .gift-banner__image--bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.35;
  }

  .gift-banner__image--bg img {
    width: 100%;
    max-width: 500px;
    height: auto;
    object-fit: contain;
  }

  .gift-banner__image--desktop {
    display: none;
  }

  .gift-banner__bottom-bar {
    padding: 14px 20px;
    background-color: var(--gift-gray);
    border-top: 1px solid #e5e5e5;
    text-align: center;
  }

  .gift-banner__bottom-bar p {
    margin: 0;
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    line-height: 1.5;
    color: #555;
  }

  @media screen and (min-width: 750px) {
    .gift-banner__hero {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      text-align: left;
      padding: 48px 40px 56px;
      min-height: 420px;
    }

    .gift-banner__hero--has-image .gift-banner__image--bg {
      display: none;
    }

    .gift-banner__image--desktop {
      display: flex;
      justify-content: flex-end;
      align-items: center;
      position: relative;
      z-index: 1;
    }

    .gift-banner__image--desktop img {
      width: 100%;
      max-width: 520px;
      height: auto;
      object-fit: contain;
    }

    .gift-banner__description {
      font-size: 0.9375rem;
      margin-bottom: 28px;
    }

    .gift-banner__bottom-bar {
      padding: 16px 40px;
    }
  }

  @media screen and (min-width: 990px) {
    .gift-banner__hero {
      padding: 56px 60px 64px;
    }

    .gift-banner__bottom-bar {
      padding-left: 60px;
      padding-right: 60px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Gift Banner",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gift to delight your loved ones this holiday season.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Decorative illustration"
    },
    {
      "type": "text",
      "id": "bottom_bar_text",
      "label": "Bottom bar text",
      "default": "Sustainable, ethically made activewear"
    }
  ],
  "presets": [
    {
      "name": "Gift Banner"
    }
  ]
}
{% endschema %}
