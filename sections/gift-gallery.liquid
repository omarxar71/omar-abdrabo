{% comment %}
  Gift Guide lifestyle gallery - image grid with shoppable hotspots
{% endcomment %}

<div class="gift-gallery" id="GiftGallery-{{ section.id }}">
  {% if section.settings.heading != blank %}
    <h2 class="gift-gallery__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="gift-gallery__grid">
    {% for block in section.blocks %}
      <div class="gift-gallery__item" {{ block.shopify_attributes }}>
        {% if block.settings.image %}
          {{
            block.settings.image
            | image_url: width: 800
            | image_tag: loading: 'lazy', widths: '400,600,800', sizes: '(min-width: 750px) 33vw, 50vw', class: 'gift-gallery__image'
          }}
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'gift-gallery__image gift-gallery__placeholder' }}
        {% endif %}

        {% if block.settings.product != blank %}
          <button
            type="button"
            class="gift-gallery__hotspot"
            aria-label="View {{ block.settings.product.title }}"
            data-product-url="{{ block.settings.product.url }}"
          >
            <span aria-hidden="true">+</span>
          </button>
        {% elsif block.settings.link != blank %}
          <a href="{{ block.settings.link }}" class="gift-gallery__hotspot" aria-label="View product">
            <span aria-hidden="true">+</span>
          </a>
        {% else %}
          <span class="gift-gallery__hotspot" aria-hidden="true">
            <span>+</span>
          </span>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

<script>
  (() => {
    const section = document.getElementById('GiftGallery-{{ section.id }}');
    if (!section) return;

    section.querySelectorAll('.gift-gallery__hotspot[data-product-url]').forEach((hotspot) => {
      hotspot.addEventListener('click', () => {
        window.location.href = hotspot.dataset.productUrl;
      });
    });
  })();
</script>

{% stylesheet %}
  .gift-gallery {
    padding: 40px 16px 56px;
    background: #fff;
    text-align: center;
  }

  .gift-gallery__heading {
    margin: 0 0 32px;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 400;
    font-style: italic;
    letter-spacing: -0.01em;
  }

  .gift-gallery__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .gift-gallery__item {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: #f5f5f5;
  }

  .gift-gallery__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .gift-gallery__item:hover .gift-gallery__image {
    transform: scale(1.03);
  }

  .gift-gallery__placeholder {
    background: #eee;
  }

  .gift-gallery__hotspot {
    position: absolute;
    bottom: 12px;
    right: 12px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: none;
    background: #fff;
    color: #1a1a1a;
    font-size: 1.25rem;
    font-weight: 300;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 2px 8px rgb(0 0 0 / 15%);
    text-decoration: none;
    transition: transform 0.2s ease;
    padding: 0;
  }

  .gift-gallery__hotspot:hover {
    transform: scale(1.1);
  }

  @media screen and (min-width: 750px) {
    .gift-gallery {
      padding: 48px 40px 64px;
    }

    .gift-gallery__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }

    .gift-gallery__hotspot {
      width: 36px;
      height: 36px;
      bottom: 16px;
      right: 16px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Gift Gallery",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Linked product"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom link",
          "info": "Used if no product is selected"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gift Gallery",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
